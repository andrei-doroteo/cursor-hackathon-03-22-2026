# Maple Tariff Disruptors — environment template
# See project-spec.md (Implementation): Diffy news → DB, tagged news → OpenAI → business
# dashboard; marketplace products; business vs. customer accounts (NextAuth).

# Copy to `.env` and fill in values. Never commit real secrets.

# When adding variables, update `/src/env.js` as well.

# --- Database (Prisma) — stores news articles, products, users, reviews ---
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="file:./db.sqlite"

# --- Auth — business + customer sign-in (project-spec: two account types) ---
# Generate: openssl rand -base64 32
# Reads NEXTAUTH_SECRET first, then AUTH_SECRET.
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# --- OpenAI — LLM summaries & action steps from relevant tagged news ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# --- Diffy — cron-fed news ingestion (project-spec: request news, store in DB) ---
# HTTPS endpoint that returns JSON (array or { articles | data | items | results }).
DIFFY_API_URL="https://example.com/api/news"
DIFFY_API_KEY=""

# --- Secured cron — verify caller when hitting /api/cron/fetch-news ---
CRON_SECRET=""
